# Runtime
BINANCE50_ENV=local
BINANCE50_ENVIRONMENT_PROFILE=local_paper_spot
BINANCE50_TRADING_MODE=paper
BINANCE50_EXCHANGE=binance
BINANCE50_MARKET_SCOPE=spot
BINANCE50_ACCOUNT_DOMAIN=spot

# Connector flags
BINANCE50_CONNECTION_ENABLED=false
BINANCE50_WEBSOCKET_ENABLED=false
BINANCE50_USER_DATA_STREAM_ENABLED=false
BINANCE50_ORDER_GATEWAY_ENABLED=false

# Binance credentials - keep empty in template
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_API_KEY_LABEL=
BINANCE_API_PERMISSION_READ=false
BINANCE_API_PERMISSION_SPOT_TRADE=false
BINANCE_API_PERMISSION_FUTURES_TRADE=false
BINANCE_API_PERMISSION_MARGIN_TRADE=false
BINANCE_API_IP_RESTRICTED=false
BINANCE_API_ALLOWED_IPS=

# Telegram credentials - keep empty in template
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Safety flags
BINANCE50_ENABLE_LIVE_TRADING=false
BINANCE50_CONFIRM_LIVE_TRADING=false
BINANCE50_ALLOW_LIVE_ORDERS=false
BINANCE50_ALLOW_TESTNET_ORDERS=false
BINANCE50_ALLOW_DEMO_ORDERS=false
BINANCE50_REQUIRE_MANUAL_LIVE_UNLOCK=true
BINANCE50_REQUIRE_MAINNET_CONFIRMATION=true
BINANCE50_LIVE_UNLOCK=
BINANCE50_LIVE_RISK_ACK=
BINANCE50_DRY_RUN=true
BINANCE50_FORCE_PAPER_MODE=true
BINANCE50_DISABLE_ALL_ORDERS=true

# Operational safety
BINANCE50_MAX_DAILY_LOSS_PCT=1.0
BINANCE50_MAX_POSITION_RISK_PCT=0.25
BINANCE50_MAX_OPEN_POSITIONS=3
BINANCE50_MAX_ORDERS_PER_HOUR=20
