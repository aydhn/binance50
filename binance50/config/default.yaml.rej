--- binance50/config/default.yaml
+++ binance50/config/default.yaml
@@ -1071,3 +1071,139 @@
     warn_uncalibrated_model: true
     reject_live_or_paper_intent: true

+ml_inference:
+  enabled: true
+  output_dataset_name: ml_inference_runs
+  cache_enabled: true
+  cache_dir: data/ml/inference/cache
+  export_dir: data/ml/inference/exports
+  reports_dir: data/ml/inference/reports
+  registry_dir: data/ml/inference/registry
+
+  real_exchange_forbidden: true
+  paper_trade_forbidden: true
+  live_trade_forbidden: true
+  order_creation_forbidden: true
+  api_key_forbidden: true
+  signed_request_forbidden: true
+  dashboard_forbidden: true
+  prediction_serving_forbidden: true
+  online_inference_forbidden: true
+  execution_integration_forbidden: true
+  signal_auto_write_forbidden: true
+  risk_auto_write_forbidden: true
+  auto_strategy_update_forbidden: true
+  auto_model_promotion_forbidden: true
+
+  model_source:
+    require_training_registry: true
+    require_model_card: true
+    require_artifact_metadata: true
+    require_artifact_hash: true
+    require_dataset_manifest_link: true
+    require_feature_columns_hash: true
+    allow_untrusted_artifact_load: false
+    allow_registry_external_paths: false
+    allow_manual_artifact_path: false
+    trusted_artifact_only: true
+    verify_artifact_hash_before_load: true
+    verify_environment_metadata: true
+    warn_environment_mismatch: true
+    block_environment_mismatch: false
+
+  dataset:
+    require_ml_dataset_manifest: true
+    require_leakage_free_dataset: true
+    require_quality_passed_dataset: true
+    use_latest_dataset_if_not_specified: true
+    allow_inference_on_train_split: true
+    allow_inference_on_validation_split: true
+    allow_inference_on_test_split: true
+    allow_inference_on_new_offline_dataset: true
+    new_offline_dataset_requires_schema_match: true
+    reject_if_feature_contains_label: true
+    reject_if_feature_contains_future: true
+    reject_if_feature_contains_target: true
+    reject_if_feature_contains_order_execution: true
+
+  feature_schema:
+    require_exact_feature_columns: true
+    require_exact_feature_order: true
+    allow_missing_features: false
+    allow_extra_features: false
+    allow_dtype_cast_numeric: true
+    reject_object_features: true
+    reject_nan_inf_features: true
+    max_nan_ratio_per_feature: 0.0
+    feature_schema_hash_required: true
+
+  preprocessing:
+    transform_only: true
+    fit_forbidden: true
+    require_training_preprocessor_metadata: true
+    require_preprocessor_hash: true
+    allow_refit: false
+    allow_validation_fit: false
+    allow_test_fit: false
+    allow_inference_fit: false
+    imputer_transform_only: true
+    scaler_transform_only: true
+    clipper_transform_only: true
+
+  prediction:
+    mode: offline_batch
+    allowed_modes:
+      - offline_batch
+    max_rows_per_batch: 100000
+    batch_size: 10000
+    deterministic: true
+    random_seed: 42
+    require_predict_output: true
+    require_predict_proba_if_classifier_supports: true
+    allow_decision_function: true
+    store_raw_predictions: true
+    store_probabilities: true
+    store_confidence: true
+    prediction_intent: research_only
+    output_trade_signal_forbidden: true
+    output_order_intent_forbidden: true
+
+  probability:
+    enabled: true
+    require_probability_metadata: true
+    calibrated_probability_preferred: true
+    allow_uncalibrated_probability: true
+    warn_uncalibrated_probability: true
+    min_probability: 0.0
+    max_probability: 1.0
+    reject_probability_out_of_range: true
+    normalize_probability_rows: false
+    reject_probability_sum_invalid: true
+    probability_sum_tolerance: 0.000001
+
+  calibration_check:
+    enabled: true
+    compute_brier_score_if_labels_available: true
+    compute_ece_if_labels_available: true
+    compute_reliability_bins_if_labels_available: true
+    reliability_bins: 10
+    require_label_for_calibration_metrics: false
+    warn_if_labels_missing: true
+    compare_to_training_calibration_report: true
+    max_brier_degradation_warning: 0.05
+    max_ece_warning: 0.10
+
+  threshold_sweep:
+    enabled: true
+    research_only: true
+    thresholds:
+      - 0.50
+      - 0.55
+      - 0.60
+      - 0.65
+      - 0.70
+      - 0.75
+      - 0.80
+    compute_precision_recall_by_threshold: true
+    compute_prediction_count_by_threshold: true
+    compute_coverage_by_threshold: true
