project:
  name: binance50
  version: 0.1.0
runtime:
  environment_profile: local_paper_spot
  exchange: binance
  environment: local
  trading_mode: paper
  market_scope: spot
  account_domain: spot
  timezone: UTC
safety:
  dry_run: true
  force_paper_mode: true
  disable_all_orders: true
  allow_testnet_orders: false
  allow_demo_orders: false
  allow_live_orders: false
  enable_live_trading: false
  confirm_live_trading: false
  require_manual_live_unlock: true
  require_mainnet_confirmation: true
  live_unlock_phrase_required: I_UNDERSTAND_REAL_MONEY_RISK
  live_risk_ack_required: I_ACCEPT_FULL_RESPONSIBILITY
  max_daily_loss_pct: 1.0
  max_position_risk_pct: 0.25
  max_open_positions: 3
  max_orders_per_hour: 20
  max_symbols_initial: 5
  default_quote_asset: USDT
  readonly_mainnet_allowed: true
credentials:
  binance:
    api_key: null
    api_secret: null
    api_key_label: null
    permission_read: false
    permission_spot_trade: false
    permission_futures_trade: false
    permission_margin_trade: false
    ip_restricted: false
    allowed_ips: []
  telegram:
    bot_token: null
    chat_id: null
connector:
  connection_enabled: false
  mock_enabled: false
  order_gateway_enabled: false
  websocket_enabled: false
  user_data_stream_enabled: false
  request_timeout_seconds: 10
  recv_window_ms: 5000
  max_retry_attempts: 3
  backoff_initial_seconds: 0.5
  backoff_max_seconds: 8.0
  max_connection_lifetime_hours: 24
  websocket_ping_timeout_seconds: 60
  websocket_reconnect_before_disconnect_minutes: 10
  max_incoming_messages_per_second: 10
  rate_limit_backoff_enabled: true
  circuit_breaker_enabled: true
  allow_real_network_in_phase5: false
logging:
  level: INFO
  log_dir: logs
data:
  root_dir: data
reports:
  root_dir: reports
market_data:
  enabled: true
  real_fetch_enabled: false
  source: binance_public
  prefer_market_data_only_endpoint: true
  base_data_endpoint: https://data-api.binance.vision
  spot_klines_path: /api/v3/klines
  usdm_klines_path: /fapi/v1/klines
  default_intervals:
  - 1m
  - 5m
  - 15m
  - 1h
  - 4h
  - 1d
  allowed_intervals:
  - 1m
  - 3m
  - 5m
  - 15m
  - 30m
  - 1h
  - 2h
  - 4h
  - 6h
  - 8h
  - 12h
  - 1d
  - 3d
  - 1w
  - 1M
  default_history_days:
    1m: 30
    3m: 60
    5m: 90
    15m: 180
    30m: 365
    1h: 730
    2h: 730
    4h: 1095
    6h: 1095
    8h: 1095
    12h: 1095
    1d: 1825
    3d: 1825
    1w: 3650
    1M: 3650
  spot_max_limit: 1000
  usdm_max_limit: 1500
  request_limit_safety_margin_pct: 90
  exclude_incomplete_last_candle: true
  require_closed_candles: true
  allow_partial_candle_cache: false
  cache_enabled: true
  cache_format: parquet
  cache_dir: data/ohlcv
  metadata_dir: data/ohlcv/metadata
  export_dir: data/ohlcv/exports
  cache_partitioning:
    by_market_scope: true
    by_symbol: true
    by_interval: true
  incremental_enabled: true
  overlap_candles_on_update: 2
  max_gap_fill_attempts: 3
  validate_after_fetch: true
  validate_after_cache_load: true
  min_rows_required: 100
  max_rows_per_symbol_interval: 2000000
  quality:
    reject_duplicate_open_time: true
    reject_out_of_order: true
    reject_negative_prices: true
    reject_zero_or_negative_close: true
    reject_high_low_inconsistency: true
    reject_negative_volume: true
    warn_zero_volume: true
    detect_gaps: true
    max_gap_ratio_pct: 1.0
    allow_weekend_crypto_continuity: true
    timezone: UTC
streams:
  enabled: true
  market_stream_real_connect_enabled: false
  use_combined_streams: true
  default_stream_types:
  - kline
  - bookTicker
  - miniTicker
  allowed_stream_types:
  - kline
  - miniTicker
  - ticker
  - bookTicker
  - partialDepth
  - diffDepth
  - trade
  - aggTrade
  - markPrice
  - forceOrder
  default_kline_interval: 1m
  allowed_kline_intervals:
  - 1m
  - 3m
  - 5m
  - 15m
  - 30m
  - 1h
  - 2h
  - 4h
  - 6h
  - 8h
  - 12h
  - 1d
  - 3d
  - 1w
  - 1M
  max_symbols_per_stream_plan: 20
  max_streams_per_connection_spot: 1024
  max_streams_per_connection_usdm: 1024
  max_control_messages_per_second_spot: 5
  max_control_messages_per_second_usdm: 10
  buffer_max_events: 10000
  buffer_drop_policy: reject_new
  buffer_warn_threshold_pct: 80.0
  stale_event_threshold_seconds: 30
  max_event_time_skew_ms: 5000
  require_monotonic_event_time: false
  detect_duplicate_events: true
  duplicate_cache_size: 5000
  replay_enabled: true
  replay_speed_multiplier: 1.0
  realtime_store_enabled: true
  persist_realtime_snapshots: false
  lifecycle:
    max_connection_lifetime_hours: 24
    reconnect_before_disconnect_minutes: 10
    ping_timeout_seconds: 60
    pong_timeout_seconds: 600
    reconnect_backoff_initial_seconds: 1.0
    reconnect_backoff_max_seconds: 60.0
storage:
  enabled: true
  root_dir: data/warehouse
  parquet_root_dir: data/warehouse/parquet
  sqlite_catalog_path: data/warehouse/catalog/binance50_catalog.sqlite
  manifest_dir: data/warehouse/manifests
  reports_dir: data/warehouse/reports
  backups_dir: data/warehouse/backups
  exports_dir: data/warehouse/exports
  temp_dir: data/warehouse/tmp
  lock_dir: data/warehouse/locks
  parquet:
    enabled: true
    compression: zstd
    fallback_compression: snappy
    use_dictionary: true
    write_statistics: true
    row_group_size: 100000
    max_rows_per_file: 500000
    partition_style: hive
    schema_validation: true
    atomic_write: true
    temp_write_suffix: .tmp
    allow_overwrite: false
    allow_append: true
    allow_upsert: true
  sqlite:
    enabled: true
    journal_mode: WAL
    synchronous: NORMAL
    foreign_keys: true
    busy_timeout_ms: 5000
    integrity_check_on_start: true
    quick_check_on_doctor: true
    vacuum_on_compaction: false
    backup_before_migration: true
  partitioning:
    by_market_scope: true
    by_symbol: true
    by_interval: true
    by_year: true
    by_month: true
    by_day: false
  datasets:
    ohlcv_dataset_name: ohlcv
    universe_dataset_name: universe_selection
    stream_events_dataset_name: stream_events
    quality_dataset_name: quality_reports
    allowed_dataset_names:
    - ohlcv
    - universe_selection
    - stream_events
    - quality_reports
    - feature_store_future
    - backtest_results_future
  integrity:
    compute_file_hash: true
    compute_dataframe_hash: true
    verify_after_write: true
    verify_before_read: true
    reject_schema_drift: true
    reject_duplicate_primary_keys: true
    reject_empty_dataset: true
  retention:
    enabled: false
    max_versions_per_dataset: 20
    keep_latest_versions: 5
    archive_old_versions: true
    delete_archived_after_days: 365
  backup:
    enabled: true
    backup_catalog: true
    backup_manifests: true
    backup_parquet_metadata_only: true
    max_backups: 20
  safety:
    allow_delete: false
    allow_destructive_migration: false
    require_backup_before_migration: true
    block_paths_outside_project: true
    block_secret_columns: true
    block_unknown_dataset_names: true
indicators:
  enabled: true
  default_backend: native
  allowed_backends:
  - native
  - talib_optional
  - pandas_ta_optional
  fail_if_optional_backend_missing: false
  input_source_priority:
  - warehouse
  - market_data_cache
  - fixture
  output_dataset_name: indicators
  cache_enabled: true
  cache_dir: data/indicators
  export_dir: data/indicators/exports
  require_closed_candles: true
  drop_incomplete_last_candle: true
  prevent_lookahead_bias: true
  enforce_monotonic_time: true
  reject_duplicate_open_time: true
  min_rows_required: 100
  max_columns_allowed: 500
  max_indicator_specs_per_run: 100
  float_precision: float64
  fill_policy: none
  warmup_policy:
    keep_warmup_rows: true
    mark_warmup_rows: true
    min_valid_ratio: 0.7
  default_periods:
    short: 9
    medium: 14
    long: 21
    slow: 50
    very_slow: 200
  trend:
    enabled: true
    sma_periods:
    - 9
    - 20
    - 50
    - 100
    - 200
    ema_periods:
    - 9
    - 12
    - 20
    - 26
    - 50
    - 100
    - 200
    wma_periods:
    - 9
    - 20
    - 50
    dema_periods:
    - 20
    - 50
    tema_periods:
    - 20
    - 50
    macd:
      enabled: true
      fast: 12
      slow: 26
      signal: 9
    adx:
      enabled: true
      period: 14
    aroon:
      enabled: true
      period: 14
  momentum:
    enabled: true
    rsi_periods:
    - 7
    - 14
    - 21
    stochastic:
      enabled: true
      k_period: 14
      d_period: 3
      smooth_k: 3
    stoch_rsi:
      enabled: true
      rsi_period: 14
      stoch_period: 14
      k_period: 3
      d_period: 3
    roc_periods:
    - 5
    - 10
    - 20
    mom_periods:
    - 5
    - 10
    - 20
    cci_periods:
    - 14
    - 20
    willr_periods:
    - 14
  volatility:
    enabled: true
    atr_periods:
    - 14
    - 21
    natr_periods:
    - 14
    bollinger:
      enabled: true
      period: 20
      stddev: 2.0
    keltner:
      enabled: true
      period: 20
      atr_period: 14
      multiplier: 2.0
    donchian:
      enabled: true
      period: 20
    rolling_std_periods:
    - 10
    - 20
    - 50
  volume:
    enabled: true
    obv: true
    vwap:
      enabled: true
      session_mode: rolling
      rolling_period: 20
    mfi_periods:
    - 14
    cmf_periods:
    - 20
    adl: true
    volume_sma_periods:
    - 20
    - 50
    volume_ema_periods:
    - 20
  transforms:
    enabled: true
    returns_periods:
    - 1
    - 3
    - 5
    - 10
    log_returns: true
    hl_range: true
    oc_change: true
    typical_price: true
    weighted_close: true
    median_price: true
  quality:
    reject_all_nan_indicator: true
    reject_constant_indicator: false
    warn_high_nan_ratio: true
    max_nan_ratio: 0.4
    detect_inf: true
    detect_extreme_values: true
    extreme_zscore_threshold: 20.0
indicator_v2:
  enabled: true
  output_dataset_name: indicator_features_v2
  cache_enabled: true
  cache_dir: data/indicators_v2
  export_dir: data/indicators_v2/exports
  prevent_lookahead_bias: true
  require_closed_candles: true
  reject_future_columns: true
  max_feature_columns: 1000
  max_feature_groups: 100
  max_mtf_sources_per_run: 5
  pivots:
    enabled: true
    method: causal_window
    left_window: 3
    min_prominence_pct: 0.1
    min_distance_bars: 3
    use_centered_window: false
    allow_repainting: false
    confirm_after_bars: 0
    max_pivots_per_series: 5000
  divergence:
    enabled: true
    lookback_bars: 100
    max_pivot_pair_distance: 50
    min_pivot_distance: 3
    price_source: close
    indicator_sources:
    - mom_rsi_14
    - trend_macd_hist_12_26_9
    - mom_stoch_k_14_3_3
    - mom_cci_20
    - volu_obv
    - volu_mfi_14
    - volu_cmf_20
    detect_regular: true
    detect_hidden: true
    require_price_pivot: true
    require_indicator_pivot: true
    min_indicator_delta_pct: 0.05
    min_price_delta_pct: 0.05
    score_enabled: true
    max_divergence_score: 100.0
    output_flags: true
    output_scores: true
  mtf:
    enabled: true
    base_intervals:
    - 1m
    - 5m
    - 15m
    higher_intervals:
    - 15m
    - 1h
    - 4h
    - 1d
    alignment_method: asof_backward
    require_higher_tf_closed: true
    max_alignment_tolerance_bars: 1
    add_higher_tf_prefix: true
    prefix_template: mtf_{interval}_
    disallow_forward_alignment: true
    disallow_nearest_alignment: true
    drop_unmatched_rows: false
    mark_unmatched_rows: true
  feature_groups:
    enabled: true
    groups:
      trend:
        prefixes:
        - trend_
      momentum:
        prefixes:
        - mom_
      volatility:
        prefixes:
        - vol_
      volume:
        prefixes:
        - volu_
      transforms:
        prefixes:
        - tr_
      divergence:
        prefixes:
        - div_
      mtf:
        prefixes:
        - mtf_
      patterns:
        prefixes:
        - pat_
    require_group_metadata: true
    allow_ungrouped_features: false
  patterns:
    enabled: true
    native_pattern_skeleton_enabled: true
    talib_pattern_adapter_enabled: true
    fail_if_talib_missing: false
    output_prefix: pat_
    supported_initial_patterns:
    - doji_skeleton
    - hammer_skeleton
    - engulfing_skeleton
    full_pattern_engine_deferred: true
  quality:
    reject_all_nan_feature: true
    reject_inf: true
    warn_high_nan_ratio: true
    max_nan_ratio: 0.5
    reject_duplicate_feature_names: true
    reject_unregistered_feature: true
    reject_lookahead_columns: true
    detect_feature_correlation: false
    correlation_warning_threshold: 0.98
strategies:
  enabled: true
  output_dataset_name: strategy_candidates
  cache_enabled: true
  cache_dir: data/strategies
  export_dir: data/strategies/exports
  execution_forbidden: true
  order_creation_forbidden: true
  paper_trade_forbidden: true
  backtest_forbidden: true
  live_trade_forbidden: true
  require_explanations: true
  require_feature_metadata: true
  require_closed_candles: true
  prevent_lookahead_bias: true
  reject_future_columns: true
  reject_target_columns: true
  reject_label_columns: true
  max_candidates_per_symbol_interval: 100
  max_plugins_per_run: 20
  max_conditions_per_plugin: 50
  min_rows_required: 100
  warmup_rows_allowed: false
  candidate:
    allowed_directions:
    - bullish
    - bearish
    - neutral
    - no_action
    allowed_strengths:
    - weak
    - medium
    - strong
    min_confidence: 0.0
    max_confidence: 100.0
    default_expiry_bars: 3
    max_expiry_bars: 50
    allow_actionable_order_language: false
    require_non_order_intent: true
  plugins:
    trend_following:
      enabled: true
      required_features:
      - trend_ema_20
      - trend_ema_50
      - trend_ema_200
      - trend_adx_14
      min_adx: 18.0
      strong_adx: 25.0
      ema_fast: trend_ema_20
      ema_mid: trend_ema_50
      ema_slow: trend_ema_200
    mean_reversion:
      enabled: true
      required_features:
      - mom_rsi_14
      - vol_bb_lower_20_2
      - vol_bb_upper_20_2
      - vol_bb_mid_20_2
      rsi_oversold: 30.0
      rsi_overbought: 70.0
      require_bollinger_touch: true
    momentum_continuation:
      enabled: true
      required_features:
      - mom_rsi_14
      - trend_macd_hist_12_26_9
      - mom_roc_10
      rsi_min: 50.0
      roc_min: 0.0
      require_macd_hist_positive_for_bullish: true
      require_macd_hist_negative_for_bearish: true
    volatility_breakout:
      enabled: true
      required_features:
      - vol_atr_14
      - vol_donchian_high_20
      - vol_donchian_low_20
      breakout_buffer_atr: 0.1
      require_atr_positive: true
    volume_confirmation:
      enabled: true
      required_features:
      - volu_obv
      - volu_volume_sma_20
      - volume
      volume_multiplier: 1.25
      require_volume_above_average: true
    divergence_candidate:
      enabled: true
      required_prefixes:
      - div_
      min_divergence_score: 40.0
      accept_regular: true
      accept_hidden: true
    mtf_confirmation:
      enabled: true
      required_prefixes:
      - mtf_
      require_mtf_trend_agreement: false
      min_confirming_timeframes: 1
    pattern_candidate:
      enabled: true
      required_prefixes:
      - pat_
      min_pattern_confidence: 40.0
    composite_skeleton:
      enabled: true
      aggregate_only: true
      final_signal_scoring_deferred: true
      min_plugins_agreeing: 2
  quality:
    reject_empty_candidate_set: false
    warn_empty_candidate_set: true
    reject_duplicate_candidates: true
    reject_missing_explanation: true
    reject_order_like_language: true
    reject_confidence_out_of_range: true
    warn_conflicting_candidates: true
    max_conflicting_candidates_per_bar: 5
backtest:
  enabled: true
  output_dataset_name: backtest_runs
  cache_enabled: true
  cache_dir: data/backtest
  export_dir: data/backtest/exports
  reports_dir: data/backtest/reports
  real_exchange_forbidden: true
  binance_client_forbidden: true
  order_gateway_forbidden: true
  testnet_order_forbidden: true
  live_order_forbidden: true
  signed_request_forbidden: true
  api_key_forbidden: true
  mode:
    engine: event_driven
    deterministic: true
    random_seed: 42
    allow_randomness: false
    single_symbol_default: true
    multi_symbol_enabled: true
    portfolio_backtest_enabled: false
  data:
    source_priority:
    - warehouse
    - market_data_cache
    - fixture
    require_ohlcv_quality_passed: true
    reject_duplicate_open_time: true
    reject_gaps: false
    warn_gaps: true
    reject_out_of_order: true
    reject_incomplete_last_candle: true
    min_rows_required: 300
    warmup_rows_for_indicators: 250
    trade_after_warmup_only: true
    require_closed_candles: true
  timing:
    decision_price_source: close
    fill_model: next_bar_open
    allow_same_bar_fill: false
    require_next_candle_for_fill: true
    decision_on_closed_candle_only: true
    fill_on_future_candle_only: true
    max_signal_age_bars: 3
    expire_signal_if_not_filled: true
  capital:
    starting_cash_usdt: 1000.0
    quote_currency: USDT
    allow_negative_cash: false
    allow_margin: false
    allow_short_spot: false
    max_cash_usage_pct: 30.0
    max_open_positions: 3
    max_positions_per_symbol: 1
  sizing:
    mode: fixed_notional
    fixed_notional_usdt: 50.0
    max_notional_usdt: 100.0
    use_risk_notional_cap: true
    risk_cap_required: true
    quantity_is_simulated_only: true
    produce_real_order_quantity: false
  fees:
    enabled: true
    maker_fee_bps: 10.0
    taker_fee_bps: 10.0
    default_fee_side: taker
    include_fees_in_pnl: true
  slippage:
    enabled: true
    model: bps
    default_slippage_bps: 2.0
    max_slippage_bps: 20.0
    volatility_slippage_multiplier: 1.5
    spread_slippage_multiplier: 1.0
    include_slippage_in_pnl: true
  exits:
    enabled: true
    close_on_opposite_signal: true
    close_on_signal_expiry: false
    close_on_end_of_backtest: true
    max_holding_bars_enabled: true
    max_holding_bars: 100
    stop_loss_deferred: true
    take_profit_deferred: true
    trailing_stop_deferred: true
  metrics:
    enabled: true
    compute_equity_curve: true
    compute_drawdown: true
    compute_win_rate: true
    compute_profit_factor: true
    compute_expectancy: true
    compute_avg_trade: true
    compute_exposure_time: true
    compute_turnover: true
    compute_fee_impact: true
    compute_slippage_impact: true
    compute_benchmark_placeholder: true
    risk_free_rate_annual: 0.0
  benchmark:
    enabled: true
    method: buy_and_hold_placeholder
    same_period: true
    include_fees: false
    include_slippage: false
    benchmark_symbol_same_as_test: true
  leakage:
    prevent_lookahead_bias: true
    reject_future_columns: true
    reject_target_columns: true
    reject_label_columns: true
    reject_forward_alignment: true
    reject_nearest_alignment: true
    require_backward_asof_alignment: true
    reject_centered_rolling: true
    reject_same_bar_fill: true
    reject_unclosed_candle_decision: true
  quality:
    reject_empty_backtest: false
    warn_empty_backtest: true
    reject_missing_trade_explanation: true
    reject_invalid_equity_curve: true
    reject_negative_cash: true
    reject_unmatched_position_close: true
    reject_position_without_fill: true
    reject_fill_without_event: true
    reject_metric_nan_inf: true
    warn_low_trade_count: true
    min_trade_count_warning: 5
backtest_reporting:
  enabled: true
  output_dataset_name: backtest_report_packs
  cache_enabled: true
  cache_dir: data/backtest/reports_v2/cache
  export_dir: data/backtest/reports_v2/exports
  report_dir: data/backtest/reports_v2/reports
  real_exchange_forbidden: true
  no_live_claims: true
  require_disclaimer: true
  require_input_hash: true
  require_config_hash: true
  require_report_hash: true
  metrics:
    enabled: true
    annualization_periods_per_year:
      crypto_daily: 365
      crypto_hourly: 8760
      crypto_4h: 2190
      crypto_1h: 8760
      crypto_15m: 35040
      crypto_5m: 105120
      crypto_1m: 525600
    default_periods_per_year: 365
    compute_cagr: true
    compute_annualized_volatility: true
    compute_sharpe: true
    compute_sortino: true
    compute_calmar: true
    compute_omega: true
    compute_tail_ratio: true
    compute_var_cvar: true
    var_confidence: 0.95
    compute_skew_kurtosis: true
    compute_payoff_ratio: true
    compute_recovery_factor: true
    compute_ulcer_index: true
    compute_expectancy: true
    compute_r_multiple_placeholder: true
    min_observations_for_ratio_metrics: 30
    min_trades_for_trade_metrics: 5
    risk_free_rate_annual: 0.0
  rolling:
    enabled: true
    windows:
    - 20
    - 50
    - 100
    compute_rolling_return: true
    compute_rolling_volatility: true
    compute_rolling_sharpe: true
    compute_rolling_drawdown: true
    compute_rolling_win_rate: true
    center_windows: false
    min_periods_ratio: 0.7
  periodic_returns:
    enabled: true
    daily: true
    weekly: true
    monthly: true
    quarterly: true
    yearly: true
    calendar_heatmap_table: true
    use_resample: true
    require_datetime_index: true
  benchmark:
    enabled: true
    compare_buy_and_hold: true
    compare_cash: true
    compare_equal_weight_placeholder: false
    compute_excess_return: true
    compute_tracking_error: true
    compute_information_ratio: true
    compute_alpha_beta_placeholder: true
    require_same_date_range: true
    benchmark_label: buy_and_hold
  drawdown:
    enabled: true
    top_n_drawdowns: 10
    compute_drawdown_duration: true
    compute_recovery_time: true
    compute_underwater_curve: true
    compute_avg_drawdown: true
    compute_max_drawdown: true
    require_recovery_metadata: true
  trade_distribution:
    enabled: true
    compute_win_loss_distribution: true
    compute_trade_return_histogram: true
    histogram_bins: 20
    compute_best_worst_trades: true
    top_n_trades: 10
    compute_consecutive_wins_losses: true
    compute_holding_time_distribution: true
  breakdowns:
    enabled: true
    by_regime: true
    by_strategy_plugin: true
    by_signal_score_tier: true
    by_risk_status: true
    by_direction: true
    by_symbol: true
    by_interval: true
    min_trades_per_bucket_warning: 3
  costs:
    enabled: true
    analyze_fees: true
    analyze_slippage: true
    compute_gross_vs_net: true
    compute_cost_drag_pct: true
    warn_high_cost_drag: true
    high_cost_drag_pct: 25.0
  report_pack:
    enabled: true
    include_summary: true
    include_metrics: true
    include_rolling_metrics: true
    include_periodic_returns: true
    include_benchmark: true
    include_drawdowns: true
    include_trade_distribution: true
    include_breakdowns: true
    include_cost_analysis: true
    include_quality: true
    include_disclaimer: true
    export_json: true
    export_markdown: true
    export_csv_tables: true
    export_html_static_skeleton: false
  adapters:
    empyrical_optional:
      enabled: true
      fail_if_missing: false
      compare_native_metrics: true
    quantstats_optional:
      enabled: true
      fail_if_missing: false
      generate_external_report: false
  quality:
    reject_nan_inf_metrics: true
    warn_low_observation_count: true
    warn_low_trade_count: true
    reject_missing_disclaimer: true
    reject_missing_hashes: true
    reject_mismatched_date_range: true
    warn_metric_instability: true
    reject_live_performance_claims: true
optimizer:
  enabled: true
  output_dataset_name: optimization_trials
  cache_enabled: true
  cache_dir: data/optimizer/cache
  export_dir: data/optimizer/exports
  reports_dir: data/optimizer/reports
  real_exchange_forbidden: true
  paper_trade_forbidden: true
  live_trade_forbidden: true
  order_creation_forbidden: true
  api_key_forbidden: true
  signed_request_forbidden: true
  dashboard_forbidden: true
  mode:
    default_method: grid
    allowed_methods:
    - grid
    - random
    - optuna_optional
    deterministic: true
    random_seed: 42
    max_trials: 100
    max_grid_combinations: 200
    max_parallel_trials: 1
    parallel_execution_enabled: false
    fail_fast: false
    continue_on_trial_failure: true
  data_split:
    enabled: true
    split_method: chronological
    train_pct: 0.6
    validation_pct: 0.2
    test_pct: 0.2
    min_train_rows: 500
    min_validation_rows: 200
    min_test_rows: 200
    embargo_bars: 0
    purge_overlapping_labels: false
    time_series_cv_enabled: true
    time_series_cv_splits: 3
    walk_forward_skeleton_enabled: true
    walk_forward_full_run_deferred: true
  search_space:
    max_parameters: 20
    max_values_per_parameter: 20
    reject_empty_space: true
    reject_unbounded_space: true
    require_parameter_descriptions: true
    allow_strategy_params: true
    allow_signal_params: true
    allow_risk_params: true
    allow_backtest_params: true
    allow_execution_params: false
    allow_live_params: false
  default_search_spaces:
    strategy:
      trend_following.min_adx:
      - 18.0
      - 20.0
      - 22.0
      - 25.0
      mean_reversion.rsi_oversold:
      - 25.0
      - 30.0
      - 35.0
      mean_reversion.rsi_overbought:
      - 65.0
      - 70.0
      - 75.0
      momentum_continuation.rsi_min:
      - 48.0
      - 50.0
      - 55.0
    signals:
      thresholds.research_candidate_min:
      - 45.0
      - 50.0
      - 55.0
      thresholds.risk_review_min:
      - 60.0
      - 65.0
      - 70.0
      confluence.same_direction_bonus_per_plugin:
      - 3.0
      - 5.0
      - 7.0
    risk:
      decision.min_final_risk_score:
      - 55.0
      - 60.0
      - 65.0
      volatility.high_volatility_penalty:
      - 10.0
      - 15.0
      - 20.0
      conflicts.high_conflict_penalty:
      - 10.0
      - 20.0
      - 30.0
    backtest:
      sizing.fixed_notional_usdt:
      - 25.0
      - 50.0
      - 75.0
      slippage.default_slippage_bps:
      - 1.0
      - 2.0
      - 5.0
      exits.max_holding_bars:
      - 50
      - 100
      - 150
  objective:
    primary_metric: robust_score
    maximize: true
    components:
      total_return_weight: 0.2
      sharpe_weight: 0.15
      sortino_weight: 0.1
      calmar_weight: 0.1
      max_drawdown_weight: -0.2
      profit_factor_weight: 0.1
      expectancy_weight: 0.1
      trade_count_weight: 0.05
      stability_weight: 0.1
      cost_drag_weight: -0.1
      overfit_penalty_weight: -0.3
    min_trade_count: 10
    min_validation_trade_count: 5
    max_drawdown_hard_limit_pct: 35.0
    max_cost_drag_pct: 30.0
    score_clamp_min: -100.0
    score_clamp_max: 100.0
  overfit:
    enabled: true
    reject_if_train_validation_gap_too_high: true
    max_train_validation_return_gap_pct: 50.0
    max_train_validation_sharpe_gap: 1.5
    reject_if_validation_bad: true
    reject_if_test_bad: false
    validation_score_min: 0.0
    test_score_min_warning: 0.0
    penalize_parameter_complexity: true
    complexity_penalty_per_parameter: 0.5
    penalize_low_trade_count: true
    penalize_high_drawdown: true
    penalize_high_cost_drag: true
    warn_best_trial_only_good_on_train: true
    require_validation_rank_consistency: true
  robustness:
    enabled: true
    compute_rank_stability: true
    compute_metric_dispersion: true
    compute_neighbor_sensitivity: true
    neighbor_distance_numeric_pct: 20.0
    top_n_trials_for_robustness: 10
    min_robustness_score: 0.0
    warn_fragile_optimum: true
  optuna_optional:
    enabled: false
    fail_if_missing: false
    sampler: tpe
    pruner: median
    n_trials: 50
    timeout_seconds: null
    direction: maximize
    study_name_prefix: binance50_optimizer
    persistent_storage_enabled: false
  quality:
    reject_no_trials: true
    reject_all_trials_failed: true
    reject_missing_objective: true
    reject_nan_inf_scores: true
    reject_missing_split_metadata: true
    reject_missing_reproducibility_hash: true
    warn_low_trial_count: true
    min_trial_count_warning: 10
    warn_no_validation_set: true
    reject_live_or_paper_intent: true
ml_dataset:
  enabled: true
  output_dataset_name: ml_datasets
  cache_enabled: true
  cache_dir: data/ml/datasets/cache
  export_dir: data/ml/datasets/exports
  registry_dir: data/ml/datasets/registry
  real_exchange_forbidden: true
  paper_trade_forbidden: true
  live_trade_forbidden: true
  order_creation_forbidden: true
  api_key_forbidden: true
  signed_request_forbidden: true
  dashboard_forbidden: true
  model_training_deferred: true
  prediction_deferred: true
  sources:
    use_indicator_v1: true
    use_indicator_v2: true
    use_strategy_candidates: false
    use_scored_signals: true
    use_regimes: true
    use_risk_assessments: true
    use_backtest_metadata: false
    use_walkforward_metadata: false
    require_source_hashes: true
    require_source_timestamps: true
  feature_selection:
    enabled: true
    include_prefixes:
    - trend_
    - mom_
    - vol_
    - volu_
    - tr_
    - div_
    - mtf_
    - pat_
    - reg_
    - signal_
    - risk_
    exclude_prefixes:
    - label_
    - target_
    - future_
    - next_
    - forward_
    - order_
    - execution_
    required_base_columns:
    - symbol
    - market_scope
    - interval
    - open_time
    - close_time
    max_feature_columns: 1500
    min_feature_columns: 10
    reject_all_nan_features: true
    reject_constant_features: false
    warn_constant_features: true
    max_nan_ratio_per_feature: 0.4
    max_inf_count: 0
    allow_object_features: false
    allow_boolean_features: true
    allow_categorical_features: true
    categorical_encoding_deferred: true
  labels:
    enabled: true
    default_label_type: forward_return_classification
    allowed_label_types:
    - forward_return_regression
    - forward_return_classification
    - volatility_adjusted_return_classification
    - triple_barrier_skeleton
    - ranking_skeleton
    horizons_bars:
    - 1
    - 3
    - 5
    - 10
    - 20
    default_horizon_bars: 5
    return_source: close
    classification_threshold_pct: 0.2
    neutral_zone_pct: 0.05
    include_neutral_class: true
    label_column_prefix: label_
    future_return_column_prefix: label_future_return_
    allow_label_columns_in_features: false
    drop_rows_without_label: true
    drop_last_horizon_rows: true
    triple_barrier:
      enabled: false
      profit_take_pct: 1.0
      stop_loss_pct: 0.5
      max_holding_bars: 20
      full_engine_deferred: true
  splits:
    enabled: true
    split_method: chronological
    train_pct: 0.6
    validation_pct: 0.2
    test_pct: 0.2
    min_train_rows: 500
    min_validation_rows: 200
    min_test_rows: 200
    time_series_cv_enabled: true
    time_series_cv_splits: 3
    embargo_bars: 0
    purge_overlapping_labels: true
    test_set_for_final_report_only: true
    reject_split_overlap: true
    reject_test_selection: true
  preprocessing:
    enabled: true
    fit_transform_train_only: true
    transform_validation_test_only: true
    scaler: standard
    allowed_scalers:
    - none
    - standard
    - robust
    - minmax
    imputation:
      enabled: true
      strategy: median_train_only
      allow_bfill: false
      allow_ffill: true
      fit_imputer_train_only: true
    clipping:
      enabled: true
      method: train_quantile
      lower_quantile: 0.001
      upper_quantile: 0.999
      fit_clipper_train_only: true
    categorical:
      enabled: false
      encoding_deferred: true
    persist_preprocessor: true
    preprocessor_registry_enabled: true
  alignment:
    enabled: true
    method: backward_asof
    reject_forward_alignment: true
    reject_nearest_alignment: true
    require_no_future_join: true
    tolerance_bars: 1
    require_closed_candles: true
  leakage:
    prevent_lookahead_bias: true
    reject_future_columns_in_features: true
    reject_target_columns_in_features: true
    reject_label_columns_in_features: true
    reject_next_columns_in_features: true
    reject_forward_columns_in_features: true
    reject_negative_shift_features: true
    allow_forward_shift_only_for_labels: true
    reject_global_scaler_fit: true
    reject_global_imputer_fit: true
    reject_global_clipper_fit: true
    reject_test_fit: true
    reject_validation_fit: true
    reject_same_bar_label_as_feature: true
  quality:
    reject_empty_dataset: true
    reject_missing_labels: true
    reject_missing_features: true
    reject_single_class_labels: false
    warn_single_class_labels: true
    warn_class_imbalance: true
    max_majority_class_ratio: 0.85
    reject_nan_inf_features: true
    reject_nan_inf_labels: true
    reject_missing_split_metadata: true
    reject_missing_hashes: true
    reject_leakage_warnings: true
    warn_low_row_count: true
    min_total_rows_warning: 1000
walkforward:
  enabled: true
  output_dataset_name: walkforward_runs
  cache_enabled: true
  cache_dir: data/walkforward/cache
  export_dir: data/walkforward/exports
  reports_dir: data/walkforward/reports
  real_exchange_forbidden: true
  paper_trade_forbidden: true
  live_trade_forbidden: true
  order_creation_forbidden: true
  api_key_forbidden: true
  signed_request_forbidden: true
  dashboard_forbidden: true
  mode:
    default_mode: rolling_window
    allowed_modes:
    - rolling_window
    - expanding_window
    - anchored_expanding
    deterministic: true
    random_seed: 42
    max_windows: 20
    min_windows_required: 3
    run_optimizer_per_window: true
    allow_fixed_params_mode: true
    max_optimizer_trials_per_window: 50
    parallel_windows_enabled: false
    max_parallel_windows: 1
    continue_on_window_failure: true
  windows:
    train_bars: 2000
    validation_bars: 500
    test_bars: 500
    step_bars: 500
    min_train_bars: 1000
    min_validation_bars: 200
    min_test_bars: 200
    embargo_bars: 0
    gap_bars_between_train_validation: 0
    gap_bars_between_validation_test: 0
    allow_overlapping_oos_windows: false
    require_equal_oos_duration: true
  expanding:
    initial_train_bars: 2000
    train_expansion_step_bars: 500
    max_train_bars: null
    anchored_start: true
  optimizer:
    method: grid
    inherit_optimizer_config: true
    override_max_trials: 50
    select_best_by: validation_robust_score
    use_test_for_selection: false
    require_overfit_guard: true
    require_robustness_guard: true
    reject_overfit_trials: true
  oos:
    enabled: true
    stitch_oos_equity: true
    compound_oos_equity: false
    reset_capital_each_window: true
    starting_cash_usdt: 1000.0
    require_oos_backtest_report: true
    min_oos_trade_count_warning: 3
    aggregate_oos_metrics: true
  stability:
    enabled: true
    compute_window_score_stability: true
    compute_oos_return_stability: true
    compute_oos_drawdown_stability: true
    compute_trade_count_stability: true
    compute_parameter_stability: true
    min_stability_score: 0.0
    max_stability_score: 100.0
    warn_unstable_windows: true
  degradation:
    enabled: true
    compare_train_validation_oos: true
    max_validation_to_oos_score_drop: 40.0
    max_validation_to_oos_return_drop_pct: 50.0
    max_validation_to_oos_sharpe_drop: 1.5
    warn_severe_degradation: true
  parameter_drift:
    enabled: true
    compute_numeric_drift: true
    compute_categorical_drift: true
    warn_high_drift: true
    high_drift_threshold: 0.6
    stable_parameter_bonus: true
  regime_analysis:
    enabled: true
    analyze_oos_by_regime: true
    analyze_window_regime_distribution: true
    warn_regime_concentration: true
    max_single_regime_oos_ratio: 0.8
    warn_regime_shift_between_train_oos: true
  robustness:
    enabled: true
    compute_window_rank_consistency: true
    compute_best_trial_recurrence: true
    compute_oos_metric_dispersion: true
    compute_oos_hit_rate_consistency: true
    compute_walkforward_robust_score: true
    min_walkforward_robust_score_warning: 40.0
  leakage:
    prevent_lookahead_bias: true
    reject_future_columns: true
    reject_target_columns: true
    reject_label_columns: true
    reject_split_overlap: true
    reject_test_selection: true
    reject_forward_alignment: true
    reject_nearest_alignment: true
    require_backward_asof_alignment: true
    reject_same_bar_fill: true
    reject_oos_overlap_when_disabled: true
  quality:
    reject_no_windows: true
    reject_all_windows_failed: true
    reject_missing_oos_results: true
    reject_missing_window_metadata: true
    reject_missing_best_trial: true
    reject_missing_hashes: true
    reject_nan_inf_metrics: true
    warn_low_window_count: true
    warn_low_oos_trade_count: true
    warn_high_parameter_drift: true
    warn_high_degradation: true
    reject_live_or_paper_intent: true
ml_training:
  enabled: true
  output_dataset_name: ml_training_runs
  cache_enabled: true
  cache_dir: data/ml/training/cache
  export_dir: data/ml/training/exports
  registry_dir: data/ml/training/registry
  artifacts_dir: data/ml/training/artifacts
  reports_dir: data/ml/training/reports
  real_exchange_forbidden: true
  paper_trade_forbidden: true
  live_trade_forbidden: true
  order_creation_forbidden: true
  api_key_forbidden: true
  signed_request_forbidden: true
  dashboard_forbidden: true
  prediction_serving_deferred: true
  execution_integration_forbidden: true
  auto_strategy_update_forbidden: true
  dataset:
    require_ml_dataset_manifest: true
    require_leakage_free_dataset: true
    require_quality_passed_dataset: true
    allowed_label_types:
    - forward_return_classification
    - forward_return_regression
    - volatility_adjusted_return_classification
    default_label_column: label_forward_return_classification_5
    require_split_metadata: true
    require_preprocessor_metadata: true
    reject_if_feature_contains_label: true
    reject_if_feature_contains_future: true
    reject_if_feature_contains_target: true
    reject_if_missing_train_validation_test: true
  task:
    default_task_type: classification
    allowed_task_types:
    - classification
    - regression_skeleton
    multiclass_enabled: true
    binary_enabled: true
    regression_default_enabled: false
    ranking_deferred: true
  models:
    enabled_models:
    - dummy_classifier
    - logistic_regression
    - random_forest_classifier
    - hist_gradient_boosting_classifier
    default_model: logistic_regression
    allow_regression_skeletons: true
    random_state: 42
    n_jobs: 1
    max_fit_seconds_per_model: 300
    max_models_per_run: 10
    allow_gpu: false
    require_deterministic_models: true
    logistic_regression:
      enabled: true
      max_iter: 1000
      class_weight: balanced
      solver: lbfgs
      C: 1.0
    random_forest_classifier:
      enabled: true
      n_estimators: 200
      max_depth: 6
      min_samples_leaf: 20
      class_weight: balanced_subsample
      random_state: 42
      n_jobs: 1
    hist_gradient_boosting_classifier:
      enabled: true
      max_iter: 200
      max_leaf_nodes: 31
      learning_rate: 0.05
      l2_regularization: 0.0
      random_state: 42
    dummy_classifier:
      enabled: true
      strategy: most_frequent
  validation:
    enabled: true
    method: time_series_split
    use_existing_ml_splits: true
    train_split_name: train
    validation_split_name: validation
    test_split_name: test
    time_series_cv_enabled: true
    time_series_cv_splits: 3
    test_set_final_report_only: true
    reject_test_selection: true
    reject_split_overlap: true
    require_chronological_order: true
    min_train_rows: 500
    min_validation_rows: 200
    min_test_rows: 200
    min_class_count_per_split: 2
    min_samples_per_class_warning: 25
  calibration:
    enabled: true
    calibrate_classifiers: true
    method: sigmoid
    allowed_methods:
    - sigmoid
    - isotonic
    calibration_split: validation
    fit_calibrator_on_test_forbidden: true
    require_calibration_report: true
    reliability_bins: 10
    compute_brier_score: true
    compute_expected_calibration_error: true
    warn_uncalibrated_probabilities: true
    isotonic_min_samples_warning: 1000
  metrics:
    classification:
      compute_accuracy: true
      compute_balanced_accuracy: true
      compute_precision_recall_f1: true
      compute_roc_auc: true
      compute_pr_auc: true
      compute_log_loss: true
      compute_brier_score: true
      compute_confusion_matrix: true
      compute_classification_report: true
      average: weighted
      zero_division: 0
    regression:
      compute_mae: true
      compute_rmse: true
      compute_r2: true
      compute_directional_accuracy: true
      regression_deferred: true
  feature_importance:
    enabled: true
    native_model_importance: true
    permutation_importance: true
    permutation_n_repeats: 5
    permutation_random_state: 42
    permutation_split: validation
    max_features_reported: 100
    warn_high_cardinality_importance_bias: true
  overfit:
    enabled: true
    compare_train_validation: true
    max_train_validation_metric_gap: 0.25
    max_train_validation_auc_gap: 0.2
    warn_if_train_much_better: true
    reject_if_validation_worse_than_dummy: false
    warn_if_validation_worse_than_dummy: true
    warn_if_test_much_worse_than_validation: true
    test_degradation_warning_gap: 0.2
  registry:
    enabled: true
    active_model_serving_forbidden: true
    auto_promote_forbidden: true
    require_model_card: true
    require_training_manifest: true
    require_dataset_manifest_link: true
    require_reproducibility_hashes: true
    persist_model_artifacts: true
    artifact_format: joblib
    persist_pickled_objects_warning: true
    allow_loading_untrusted_artifacts: false
  quality:
    reject_no_models_trained: true
    reject_all_models_failed: true
    reject_missing_metrics: true
    reject_missing_calibration_report: false
    reject_missing_model_card: true
    reject_missing_dataset_manifest: true
    reject_missing_hashes: true
    reject_nan_inf_metrics: true
    warn_low_sample_count: true
    warn_class_imbalance: true
    warn_single_class_split: true
    reject_single_class_train: true
    reject_single_class_validation: false
    warn_uncalibrated_model: true
    reject_live_or_paper_intent: true
