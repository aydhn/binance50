+                schema_version INTEGER NOT NULL,
+                status TEXT NOT NULL,
+                created_at_utc TEXT NOT NULL,
+                updated_at_utc TEXT NOT NULL,
+                description TEXT
+            )
+        """)
+
+    rec = DatasetRecord("1", "test_ds", "ohlcv", 1, "active", "2024", "2024", "desc")
